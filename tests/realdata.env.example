# Copy this file to tests/realdata.local.env and edit the local paths.
# The local file is ignored by git.

MARIO_REALDATA_ROOT="/Volumes/SanDisk SSD/Work/MARIO"

# Optional: point directly to a config file instead of using $MARIO_REALDATA_ROOT/config.yaml.
# MARIO_REALDATA_CONFIG="/Volumes/SanDisk SSD/Work/MARIO/config.yaml"

# Optional: run only matching cases. This is a Python regular expression.
# MARIO_REALDATA_FILTER="CEPALSTAT|EORA"

# Optional: also run aggregation checks. Parsing-only checks are the default.
# MARIO_REALDATA_RUN_AGGREGATE=1
